# Outhora + Claude Code Integration
# Builds a container with Claude Code CLI and Outhora authorization wrappers.

FROM node:20-slim

# Install system dependencies needed by Outhora wrappers and Claude Code
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    curl \
    git \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code globally
RUN npm install -g @anthropic-ai/claude-code

# Install Outhora wrappers
COPY wrappers/ /opt/outhora/bin/
RUN chmod +x /opt/outhora/bin/*

# Install Outhora Python SDK
COPY sdk/ /opt/outhora/sdk/
ENV PYTHONPATH="/opt/outhora:${PYTHONPATH:-}"

# Wrappers must come first in PATH so they intercept tool calls
ENV PATH="/opt/outhora/bin:${PATH}"

# Security: run as non-root
RUN groupadd -r outhora && useradd -r -g outhora -m -s /bin/bash outhora
USER outhora

WORKDIR /workspace

# Required at runtime (passed via docker-compose or --env-file):
# OUTHORA_API_URL, OUTHORA_AGENT_ID, OUTHORA_AGENT_SECRET, OUTHORA_DEPT_ID
# ANTHROPIC_API_KEY
