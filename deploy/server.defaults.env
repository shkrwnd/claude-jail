# Execution server defaults — committed, loaded by server/main.py.
# Do NOT put secrets or machine-specific values here.
#
# Override anything in deploy/server.env (gitignored, auto-created) — values
# there always win over these defaults.

# Which authorization backend approves agent actions.
# Options: outhora, webhook, allow_all, or a dotted path to a custom
# backend class (e.g. mypkg.mymodule.MyBackend).
# allow_all approves everything — fine for local dev; switch for real use.
AUTH_BACKEND=allow_all

# --- Outhora ACP (AUTH_BACKEND=outhora) ---
# Additionally requires in server.env:
#   OUTHORA_AGENT_ID, OUTHORA_AGENT_SECRET, OUTHORA_DEPT_ID
# Optional: OUTHORA_USER_ID, OUTHORA_SESSION_ID
OUTHORA_API_URL=https://api.outhora.com

# --- Webhook backend (AUTH_BACKEND=webhook) ---
# Additionally requires AUTH_WEBHOOK_URL in server.env.
# Optional: AUTH_WEBHOOK_TOKEN
AUTH_WEBHOOK_TIMEOUT=30

# --- Execution limits ---
# Max seconds an executed command may run before it is killed. Prevents a
# hung command from holding a server thread forever.
EXEC_TIMEOUT=300

# --- Workspace path mapping (container -> host) ---
# /workspace maps to WORKSPACE_DIR (default: <repo root>/workspace). Extra
# mounts are read automatically from deploy/docker-compose.override.yml.
# WORKSPACE_MAP can add or override entries:
#   WORKSPACE_MAP=/workspace/project=/Users/you/project
#
# The server listens on TCP 127.0.0.1:8377 by default. To change it:
# EXEC_PORT=1234 ./start.sh (and update EXEC_SERVER in deploy/docker-compose.yml).
