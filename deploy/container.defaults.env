# Container env defaults — committed, listed first under env_file in
# docker-compose.yml. Values in deploy/container.env (gitignored,
# auto-created) win over these.
#
# Only values the container itself needs. No auth backend credentials here —
# anything in this environment is readable by the agent.

# Claude Code settings
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
DISABLE_AUTOUPDATER=1
