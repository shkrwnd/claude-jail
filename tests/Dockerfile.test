FROM python:3.12-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir pytest

# Copy project — container side (wrappers/), host side (server/), and tests
COPY wrappers/ /opt/agent/bin/
COPY server/ /opt/agent/server/
COPY tests/ /opt/agent/tests/

RUN chmod +x /opt/agent/bin/*

ENV PYTHONPATH="/opt/agent"
ENV PATH="/opt/agent/bin:${PATH}"

WORKDIR /opt/agent

# Run as non-root
RUN groupadd -r testuser && useradd -r -g testuser -s /bin/bash testuser
USER testuser

CMD ["pytest", "tests/test_exec_client.py", "tests/test_auth_backends.py", "tests/test_outhora.py", "-v"]
